# Runtime
RUNTIME_DIR=./data
APP_SECRET=change-this-to-a-long-random-string

# Defaults for new users. Users can override inside dashboard.
BYBIT_ENV=testnet
BYBIT_AUTH_TYPE=auto
RECV_WINDOW=5000
OPENAI_MODEL=gpt-4o-mini
ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT
DEFAULT_CATEGORY=auto
DRY_RUN=true
MAX_LEVERAGE=5
MAX_MARGIN_PER_TRADE_USDT=20
MAX_NOTIONAL_USDT=100
MAX_DAILY_TRADES=5
REQUIRE_TP_SL=true
DEFAULT_TAKE_PROFIT_PCT=1.2
DEFAULT_STOP_LOSS_PCT=0.6
MIN_SECONDS_BETWEEN_TRADES=60
BOT_INTERVAL_SECONDS=30
AI_COST_SAVER=true
BYBIT_SKILL_CONTEXT_MAX_CHARS=1800

# Bybit Skill auto update
BYBIT_SKILL_MANIFEST_URL=https://api.bybit.com/skill/manifest
BYBIT_SKILL_RAW_BASE_URL=https://raw.githubusercontent.com/bybit-exchange/skills/main
BYBIT_SKILL_DIR=
